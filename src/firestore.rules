rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

      // Helper Functions for Reusability and Readability

      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingDoc() {
        return resource != null;
      }

      function isEventOwnerOnCreate() {
        return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      }

      function getUserRole(userId) {
          return get(/databases/$(database)/documents/users/$(userId)).data.role;
      }

      function isAdmin() {
          let role = getUserRole(request.auth.uid);
          return isSignedIn() && (role == 'Super Admin' || role == 'Content Admin' || role == 'Editorial Admin');
      }

      function getShow(showId) {
        return get(/databases/$(database)/documents/shows/$(showId));
      }

      function isShowOwner(showId) {
          // Use `resource.data` for existing documents
          return isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

      function getEvent(eventId) {
        return get(/databases/$(database)/documents/events/$(eventId));
      }

      function isEventOwner(eventId) {
        let eventData = getEvent(eventId).data;
        return isSignedIn() && eventData.ownerId == request.auth.uid;
      }

      function isEventPlanner(eventId) {
        return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/planners/$(request.auth.uid));
      }

      function isEventPlannerByAssignment() {
          return isSignedIn() && exists(/databases/$(database)/documents/planners/$(request.auth.uid));
      }

      function isEventCohost(eventId) {
        return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/cohosts/$(request.auth.uid));
      }

      function isEventGuest(eventId) {
          return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/guests/$(request.auth.uid));
      }

      function isEventStaff(eventId) {
        // For read operations, this is fine. For writes, be more specific.
        return isEventOwner(eventId) || isEventPlanner(eventId) || isEventCohost(eventId);
      }

      function isEventVendor(eventId, specialty) {
          // This is a simplified check. A real implementation might check a 'contracts' subcollection.
          let userRole = getUserRole(request.auth.uid);
          return isSignedIn() && userRole == 'Vendor' || userRole == specialty;
      }

      function canReadEventData(eventId) {
        return isEventStaff(eventId) || isEventGuest(eventId);
      }

      // Security rule for the 'teamMembers' collection group query
      match /{path=**}/teamMembers/{memberId} {
        // Allow user to read invitations where their UID is in the `userId` field.
        allow list, get: if isSignedIn() && request.auth.uid == resource.data.userId;

        // Allow user to update their own invitation status.
        allow update: if isSignedIn() && request.auth.uid == resource.data.userId && request.resource.data.status in ['accepted', 'declined'];
        allow create: if isEventOwnerOnCreate() || isEventStaff(path.split('/')[1]);
      }

      // Begin Collection Rules

      match /hosts/{hostId} {
         allow read, write: if isOwner(hostId);

          match /events/{eventId} {
              allow read, write: if isOwner(hostId);

              match /teamMembers/{memberId} {
                allow read, write: if isOwner(hostId);
              }
          }
      }


      match /users/{userId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if request.auth.uid == userId;
        allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.id == resource.data.id;
        allow delete: if isOwner(userId) && isExistingDoc();

        // Notifications can only be read/deleted by the user they belong to.
        // Any signed in user can create a notification for another user (e.g. for invitations).
        match /notifications/{notificationId} {
          allow read, delete: if isOwner(userId);
          allow create: if isSignedIn();
          allow update: if isOwner(userId) && request.resource.data.read == true;
        }
      }

      match /users/{document=**} {
          allow list: if isSignedIn();
      }

      match /planners/{plannerId} {
          allow read, write: if isOwner(plannerId);

          match /assignments/{assignmentId} {
              allow read, list: if isOwner(plannerId);
              allow update: if isOwner(plannerId); // Planner can accept/decline
          }
      }

      match /plannerProfiles/{plannerId} {
          allow get, list: if true;
          allow create: if request.auth.uid == plannerId;
          allow update, delete: if isOwner(plannerId);
      }

      match /ticketiers/{ticketierId} {
          allow get: if true;
          allow list: if true;
          allow create: if request.auth.uid == ticketierId;
          allow update: if isOwner(ticketierId);
          allow delete: if false;
      }

      match /vendors/{vendorId} {
          allow get, list: if true;
          allow create: if request.auth.uid == vendorId;
          allow update, delete: if isOwner(vendorId);
      }

      match /shows/{showId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isShowOwner(showId);
        allow delete: if isShowOwner(showId);
      }

      match /shows/{showId}/ticketTiers/{tierId} {
          allow get, list: if true; // Tiers are public
          allow create, update, delete: if isShowOwner(showId);
      }

      match /shows/{showId}/tickets/{ticketId} {
          allow get, list: if isShowOwner(showId) || isOwner(resource.data.buyerId);
          allow create: if isSignedIn();
          allow update, delete: if isShowOwner(showId);
      }

			match /events/{eventId} {

        allow get: if isEventStaff(eventId) || isEventPlannerByAssignment();
        allow list: if true;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if
          (isEventOwner(eventId) || isEventPlanner(eventId)) &&
          isExistingDoc() &&
          request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isEventOwner(eventId) && isExistingDoc();

        match /tasks/{taskId} {
          allow read, create, update, delete: if isEventStaff(eventId);
        }

    
        // DOCUMENT RULES
       match /guests/{guestId} {
        allow get: if true;
        allow list: if isEventStaff(eventId);
        allow create: if isEventOwner(eventId) || isEventPlanner(eventId);

        allow update: if isEventStaff(eventId) ||
                       // Guest can link or re-link their UID
                       (isSignedIn() && request.resource.data.userProfileId == request.auth.uid) ||
                       // Guest can update RSVP if UID matches
                       (isSignedIn() && request.auth.uid == resource.data.userProfileId &&
                        request.resource.data.diff(resource.data).changedKeys().hasOnly(['rsvpStatus', 'rsvpUpdatedAt']));

        allow delete: if isEventStaff(eventId);
      }

      
        match /events/{eventId}/guests/{guestCode} {
          // Guests can read their own record
          allow read: if request.auth != null
                      && request.auth.uid == resource.data.userProfileId;

          // Guests can update RSVP only
          allow update: if request.auth != null
                        && request.auth.uid == resource.data.userProfileId
                        && request.resource.data.diff(resource.data).changedKeys()
                           .hasOnly(["rsvpStatus", "rsvpUpdatedAt"]);

          // Staff / owner full access
          allow read, update, delete: if isEventStaff(eventId)
                                      || isEventOwner(eventId);

          allow create: if isEventStaff(eventId)
                        || isEventOwner(eventId);

 			}




      match /expenses/{expenseId} {
        allow read: if isEventStaff(eventId);
        allow create, update, delete: if isEventPlanner(eventId);
      }

      match /tables/{tableId} {
        allow read: if isEventStaff(eventId);
        allow write: if isEventPlanner(eventId);

        match /seats/{seatId} {
          allow read: if isEventStaff(eventId);
          allow write: if isEventPlanner(eventId);
        }
      }
        
      match /gifts/{giftId} {
        allow read: if true; // Guests need to be able to read this
        allow create, delete: if isEventStaff(eventId);
        allow update: if isSignedIn() && (isEventOwner(eventId) || isEventGuest(eventId));
      }
      
      match /songRequests/{requestId} {
        allow create: if isEventGuest(eventId);
        allow read: if isEventStaff(eventId) || isEventVendor(eventId, 'DJ/Musician') || (isEventGuest(eventId) && resource.data.requesterId == request.auth.uid);
        allow update: if isEventStaff(eventId); // For changing status
        allow delete: if isEventStaff(eventId);
      }

      match /fashionContracts/{contractId} {
          allow create: if isEventOwner(eventId) && request.resource.data.ownerId == request.auth.uid;
          allow read, update: if isEventOwner(eventId) || isOwner(resource.data.designerId);
          allow delete: if isEventOwner(eventId);

          match /messages/{messageId} {
            allow read, create: if isEventOwner(eventId) || isEventPlanner(eventId) || isOwner(get(/databases/$(database)/documents/events/$(eventId)/fashionContracts/$(contractId)).data.designerId);
            allow update, delete: if isOwner(resource.data.senderId);
          }
      }
      
      match /event_pricing/{pricingId} {
        allow read: if isEventStaff(eventId);
        allow create: if isEventOwnerOnCreate() || isEventOwner(eventId);
        allow update: if isEventOwner(eventId) && isExistingDoc();
        allow delete: if isEventOwner(eventId) && isExistingDoc();
      }

      match /program/{docId} {
        allow read: if isEventStaff(eventId);
        allow write: if isEventPlanner(eventId);
      }

      match /menu/{docId} {
        allow read: if isEventStaff(eventId) || isEventGuest(eventId) || isEventVendor(eventId, 'Caterer');
        allow write: if isEventPlanner(eventId);
      }
      
      match /shotLists/{shotListId} {
        allow read: if isEventStaff(eventId) || isEventVendor(eventId, 'Photographer') || isEventVendor(eventId, 'Videographer');
        allow write: if isEventStaff(eventId); // Owner/Planner can add/remove
        
      }
      
      match /invitations/{invitationId} {
        allow read, update: if request.auth != null
        									&& request.auth.uid == resource.data.userId
                          || isEventStaff(eventId);
        
        allow list: if isEventStaff(eventId);
        allow create: if isEventOwnerOnCreate() || isEventStaff(eventId);
        allow delete: if isEventStaff(eventId);
        }
      }

       match /events/{eventId}/moodboard/{moodboardId} {
        allow get, list: if isEventStaff(eventId) || isEventVendor(eventId, 'Decorator');
        allow create, update, delete: if isEventStaff(eventId);
      }

     match /events/{eventId}/planners/{plannerId} {
        allow get, list: if canReadEventData(eventId);

        allow create: if
          isEventOwner(eventId) ||
          isEventOwnerOnCreate();

        allow update: if isEventOwner(eventId) && isExistingDoc();
        allow delete: if isEventOwner(eventId) && isExistingDoc();

      }

      match /events/{eventId}/cohosts/{cohostId} {
        allow get, list: if canReadEventData(eventId);
        allow create: if isEventOwner(eventId);
        allow update: if isEventOwner(eventId) && isExistingDoc();
        allow delete: if isEventOwner(eventId) && isExistingDoc();
      }

      match /events/{eventId}/chat_messages/{messageId} {
        allow get, list: if canReadEventData(eventId);
        allow create: if (isEventStaff(eventId) || isEventGuest(eventId)) && request.resource.data.senderId == request.auth.uid && request.resource.data.eventId == eventId;
        allow update: if false; 
        allow delete: if (isEventStaff(eventId) || isOwner(resource.data.senderId)) && isExistingDoc();
      }

      match /events/{eventId}/media/{mediaId} {
        allow get, list: if canReadEventData(eventId);
        allow create: if isEventStaff(eventId) && request.resource.data.uploaderId == request.auth.uid && request.resource.data.eventId == eventId;
        allow update: if false; 
        allow delete: if (isEventStaff(eventId) || isOwner(resource.data.uploaderId)) && isExistingDoc();
      }

      match /price_plans/{pricePlanId} {
        allow read, list: if true;
        allow write: if false;
      }

      match /events/{eventId}/security_codes/{securityCodeId} {
        allow get: if isEventStaff(eventId) || isOwner(securityCodeId);
        allow list: if isEventStaff(eventId);
        allow create: if isEventStaff(eventId) && request.resource.data.eventId == eventId;
        allow update: if isEventStaff(eventId) && isExistingDoc();
        allow delete: if isEventStaff(eventId) && isExistingDoc();
      }

      match /events/{eventId}/announcements/{announcementId} {
        allow read: if canReadEventData(eventId);
        allow create: if isEventStaff(eventId) && request.resource.data.authorId == request.auth.uid && request.resource.data.eventId == eventId;
        allow update, delete: if isEventStaff(eventId) && isExistingDoc();
      }

      // Marketplace Rules

      match /cars/{carId} {
          allow get, list: if true;
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
          allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

          match /bookings/{bookingId} {
              allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.carOwnerId == request.auth.uid);
              allow list: if isSignedIn() && resource.data.carOwnerId == request.auth.uid;
              allow create: if isSignedIn();
              allow update, delete: if isSignedIn() && resource.data.carOwnerId == request.auth.uid;
          }
      }

      match /carBookings/{bookingId} {
          allow list, get: if request.auth != null
              && request.query.where.userId == request.auth.uid;
          allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.carOwnerId == request.auth.uid);
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource.data.carOwnerId == request.auth.uid;
      }

      match /venues/{venueId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
          allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

          match /bookings/{bookingId} {
              allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.venueOwnerId == request.auth.uid);
              allow list: if isSignedIn() && resource.data.venueOwnerId == request.auth.uid;
              allow create: if isSignedIn();
              allow update, delete: if isSignedIn() && resource.data.venueOwnerId == request.auth.uid;
          }
      }
       match /venueBookings/{bookingId} {
          allow list, get: if request.auth != null
                && request.auth.uid == resource.data.userId;
          allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.venueOwnerId == request.auth.uid);
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource.data.venueOwnerId == request.auth.uid;
      }

      match /hotels/{hotelId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
          allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

          match /bookings/{bookingId} {
              allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.hotelOwnerId == request.auth.uid);
              allow list: if isSignedIn() && resource.data.hotelOwnerId == request.auth.uid;
              allow create: if isSignedIn();
              allow update, delete: if isSignedIn() && resource.data.hotelOwnerId == request.auth.uid;
          }
      }
       match /bookings/{bookingId} {
          allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.hotelOwnerId == request.auth.uid);
          allow list, get: if request.auth != null && request.query.where.userId == request.auth.uid;
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource.data.hotelOwnerId == request.auth.uid;
      }

      match /magazineIssues/{issueId} {
          allow get: if resource.data.status == 'published' || isAdmin();
          allow list: if true; // Public can list published issues, admins can list all
          allow create, update, delete: if isAdmin();
      }

      // Administrative Rules
      match /adRequests/{requestId} {
          allow create: if isSignedIn();
          allow read, update, delete: if isAdmin();
      }

      match /testimonials/{testimonialId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if false; // Should be handled by admin roles
      }
       match /supportTickets/{ticketId} {
          allow create: if true;
          allow read, update, delete: if false; // Should be handled by admin roles
      }

    }
  }
