
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Core Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Event Roles ---
    function isEventOwner(eventId) {
      return isSignedIn() && getEvent(eventId).data.ownerId == request.auth.uid;
    }

    function isEventPlanner(eventId) {
      return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/planners/$(request.auth.uid));
    }

    function isEventCohost(eventId) {
      return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/cohosts/$(request.auth.uid));
    }

    function isEventStaff(eventId) {
      return isEventOwner(eventId) || isEventPlanner(eventId) || isEventCohost(eventId);
    }

    function isEventGuest(eventId) {
      return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/guests/$(request.auth.uid));
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /notifications/{notificationId} {
        allow read, delete: if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isOwner(userId) && request.resource.data.diff(resource.data).hasOnly(['read']);
      }
      
      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /events/{eventId} {
      allow get: if isEventStaff(eventId) || isEventGuest(eventId);
      allow list: if true; // Required for event code lookup
      allow create: if isSignedIn();
      allow update: if isEventOwner(eventId) || isEventPlanner(eventId);
      allow delete: if isEventOwner(eventId);

      match /guests/{guestId} {
        allow get: if isEventStaff(eventId) || isOwner(guestId);
        allow list: if isEventStaff(eventId);
        allow create: if isEventStaff(eventId);
        allow update: if isEventStaff(eventId) || (isOwner(guestId) && request.resource.data.diff(resource.data).hasOnly(['rsvpStatus']));
        allow delete: if isEventStaff(eventId);
      }

      match /guestCodes/{guestCode} {
        allow read: if true;
        allow write: if isEventStaff(eventId);
      }

      match /planners/{plannerId} {
        allow read: if isEventStaff(eventId) || isOwner(plannerId);
        allow write: if isEventOwner(eventId);
      }

      match /cohosts/{cohostId} {
        allow read: if isEventStaff(eventId) || isOwner(cohostId);
        allow write: if isEventOwner(eventId);
      }

      match /tasks/{taskId} {
        allow read, write: if isEventStaff(eventId);
      }

      match /expenses/{expenseId} {
        allow read: if isEventStaff(eventId);
        allow write: if isEventPlanner(eventId) || isEventOwner(eventId);
      }

      match /tables/{tableId} {
        allow read: if isEventStaff(eventId) || isEventGuest(eventId);
        allow write: if isEventPlanner(eventId);
      }

      match /seats/{seatId} {
        allow read: if isEventStaff(eventId) || isEventGuest(eventId);
        allow write: if isEventPlanner(eventId);
      }

      match /announcements/{announcementId} {
        allow read: if isEventStaff(eventId) || isEventGuest(eventId);
        allow create: if isEventStaff(eventId);
        allow delete: if isEventStaff(eventId);
      }

      match /media/{mediaId} {
        allow read: if isEventStaff(eventId) || isEventGuest(eventId);
        allow create: if isSignedIn();
      }
      
      match /menu/{docId} {
        allow read: if isEventStaff(eventId) || isEventGuest(eventId);
        allow write: if isEventStaff(eventId);
      }
      
      match /program/{docId} {
        allow read: if isEventStaff(eventId) || isEventGuest(eventId);
        allow write: if isEventStaff(eventId);
      }
      
      match /shotLists/{docId} {
        allow read, write: if isEventStaff(eventId);
      }
      
      match /moodboard/{docId} {
        allow read, write: if isEventStaff(eventId);
      }
      
      match /vendorContracts/{contractId} {
        allow read: if isEventStaff(eventId) || (isSignedIn() && request.auth.uid == resource.data.vendorId);
        allow create: if isEventPlanner(eventId) || isEventOwner(eventId);
        allow update: if isEventStaff(eventId) || (isSignedIn() && request.auth.uid == resource.data.vendorId);
      }
    }

    match /vendors/{vendorId} {
      allow get, list: if true;
      allow write: if isOwner(vendorId);
    }

    match /shows/{showId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /ticketTiers/{tierId} {
        allow get, list: if true;
        allow write: if isSignedIn() && get(/databases/$(database)/documents/shows/$(showId)).data.ownerId == request.auth.uid;
      }

      match /tickets/{ticketId} {
        allow read: if isSignedIn() && (resource.data.buyerId == request.auth.uid || get(/databases/$(database)/documents/shows/$(showId)).data.ownerId == request.auth.uid);
        allow create: if isSignedIn();
      }
    }
    
    match /hotels/{hotelId} {
      allow get, list: if true;
      allow write: if isOwner(resource.data.ownerId) || (request.method == 'create' && isSignedIn());
    }
    
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.hotelOwnerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.hotelOwnerId == request.auth.uid;
    }
    
    match /venues/{venueId} {
      allow get, list: if true;
      allow write: if isOwner(resource.data.ownerId) || (request.method == 'create' && isSignedIn());
    }
    
    match /venueBookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.venueOwnerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.venueOwnerId == request.auth.uid;
    }
    
    match /cars/{carId} {
      allow get, list: if true;
      allow write: if isOwner(resource.data.ownerId) || (request.method == 'create' && isSignedIn());
    }
    
    match /carBookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.carOwnerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.carOwnerId == request.auth.uid;
    }

    match /magazineIssues/{issueId} {
      allow get: if resource.data.status == 'published';
      allow list: if true;
    }
    
    match /testimonials/{id} {
      allow get, list: if true;
      allow create: if isSignedIn();
    }
    
    match /adRequests/{id} {
      allow create: if isSignedIn();
    }
    
    match /supportTickets/{id} {
      allow create: if true;
    }
  }
}
