
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

      // --- Start of General Helper Functions ---
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingDoc() {
        return resource != null;
      }

      function isEventOwnerOnCreate() {
        return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      }
      
      function getUserRole(userId) {
          return get(/databases/$(database)/documents/users/$(userId)).data.role;
      }

      function isAdmin() {
          let role = getUserRole(request.auth.uid);
          return isSignedIn() && (role == 'Super Admin' || role == 'Content Admin' || role == 'Editorial Admin');
      }
      // --- End of General Helper Functions ---


      // --- Start of Event-Scoped Helper Functions ---
      function getEvent(eventId) {
        return get(/databases/$(database)/documents/events/$(eventId));
      }

      function isEventOwner(eventId) {
        let event = getEvent(eventId);
        return isSignedIn() && event.data.ownerId == request.auth.uid;
      }

      function isEventPlanner(eventId) {
        let event = getEvent(eventId);
        return isSignedIn() && event.data.plannerIds != null && request.auth.uid in event.data.plannerIds;
      }

      function isEventCohost(eventId) {
        let event = getEvent(eventId);
        return isSignedIn() && event.data.cohostIds != null && event.data.cohostIds[request.auth.uid] == true;
      }

      function isEventStaff(eventId) {
        // During a create operation, `resource` is null. We check `request.resource.data` instead.
        if (request.method == 'create') {
           return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        }
        let event = getEvent(eventId);
        return isSignedIn() && (
          event.data.ownerId == request.auth.uid ||
          (event.data.plannerIds != null && request.auth.uid in event.data.plannerIds) ||
          (event.data.cohostIds != null && event.data.cohostIds[request.auth.uid] == true)
        );
      }

       function isEventGuest(eventId) {
          let guestDoc = get(/databases/$(database)/documents/events/$(eventId)/guests/$(request.auth.uid));
          return isSignedIn() && guestDoc != null;
       }
      // --- End of Event-Scoped Helper Functions ---
      

      // --- Start of Security Rule Definitions ---
      match /users/{userId} {
        allow read, create: if isOwner(userId) || request.auth == null; // Allow creation for new users
        allow update, delete: if isOwner(userId);
        allow list: if isSignedIn();

        match /notifications/{notificationId} {
          allow read, delete: if isOwner(userId);
          allow create: if isSignedIn();
          allow update: if isOwner(userId) && request.resource.data.read == true;
        }
      }

      match /planners/{plannerId} {
          allow read, write: if isOwner(plannerId);
      }

      match /plannerProfiles/{plannerId} {
          allow get, list: if true;
          allow create: if request.auth.uid == plannerId;
          allow update, delete: if isOwner(plannerId);
      }

      match /ticketiers/{ticketierId} {
          allow get, list: if true;
          allow create: if request.auth.uid == ticketierId;
          allow update: if isOwner(ticketierId);
      }

      match /vendors/{vendorId} {
          allow get, list: if true;
          allow create: if request.auth.uid == vendorId;
          allow update, delete: if isOwner(vendorId);
      }

      match /shows/{showId} {
        allow read, list: if true;
        allow create, update, delete: if isShowOwner(showId);
      }

      match /shows/{showId}/{document=**} {
          allow read, list, write: if isShowOwner(showId);
      }
      
      match /events/{eventId} {
        allow create: if isEventOwnerOnCreate();
        allow get: if isEventStaff(eventId) || isEventGuest(eventId);
        allow update, delete: if isEventStaff(eventId);
        
        match /guests/{guestId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId);
            allow create: if isEventStaff(eventId);
            allow delete: if isEventStaff(eventId);
            allow update: if isEventStaff(eventId) || 
                           (isEventGuest(eventId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvpStatus'])) ||
                           (isSignedIn() && resource.data.userProfileId == null && request.resource.data.userProfileId == request.auth.uid);
        }

        match /guestCodes/{guestCode} {
            allow read: if true; // Publicly readable for login
            allow create, update, delete: if isEventStaff(eventId);
        }

        match /tasks/{taskId} {
          allow read, write: if isEventStaff(eventId);
        }

        match /expenses/{expenseId} {
            allow read, write: if isEventStaff(eventId);
        }

        match /tables/{tableId} {
          allow read, write: if isEventStaff(eventId);
          match /seats/{seatId} {
            allow read, write: if isEventStaff(eventId);
          }
        }
        
        match /gifts/{giftId} {
          allow read, write: if isEventStaff(eventId);
        }
      
        match /songRequests/{requestId} {
          allow create: if isEventGuest(eventId);
          allow read, update, delete: if isEventStaff(eventId);
        }

        match /fashionContracts/{contractId} {
            allow create: if isEventOwner(eventId);
            allow read, update: if isEventStaff(eventId) || isOwner(resource.data.designerId);
            allow delete: if isEventOwner(eventId);
        }
      
        match /program/{docId} {
          allow read, write: if isEventStaff(eventId);
        }

        match /menu/{docId} {
          allow read, write: if isEventStaff(eventId);
        }
        
        match /shotLists/{shotListId} {
          allow read, write: if isEventStaff(eventId);
        }
        
        match /moodboard/{moodboardId} {
            allow read, write: if isEventStaff(eventId);
        }

        match /chat_messages/{messageId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId);
            allow create, update, delete: if isEventStaff(eventId) || isOwner(resource.data.senderId);
        }

        match /media/{mediaId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId);
            allow create, update, delete: if isEventStaff(eventId) || isOwner(resource.data.uploaderId);
        }

        match /security_codes/{securityCodeId} {
          allow read, list, create, update, delete: if isEventStaff(eventId);
        }

        match /announcements/{announcementId} {
          allow read: if isEventStaff(eventId) || isEventGuest(eventId);
          allow create, update, delete: if isEventStaff(eventId);
        }
      }

      match /price_plans/{pricePlanId} {
        allow read, list: if true;
        allow write: if isAdmin();
      }

      match /cars/{carId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId);
      }
      
      match /carBookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.carOwnerId);
      }

      match /venues/{venueId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId);
      }

       match /venueBookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.venueOwnerId);
      }

      match /hotels/{hotelId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId);
      }

       match /bookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.hotelOwnerId);
      }

      match /magazineIssues/{issueId} {
          allow get: if resource.data.status == 'published' || isAdmin();
          allow list: if true;
          allow create, update, delete: if isAdmin();
      }

      match /adRequests/{requestId} {
          allow create: if isSignedIn();
          allow read, update, delete: if isAdmin();
      }

      match /testimonials/{testimonialId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isAdmin();
      }
       match /supportTickets/{ticketId} {
          allow create: if true;
          allow read, update, delete: if isAdmin();
      }
    }
  }

function isShowOwner(showId) {
    return false;
}
