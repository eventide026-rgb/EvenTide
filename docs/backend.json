
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile in the EvenTide application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "User's full name."
        },
        "phoneNumber": {
          "type": "string",
          "description": "User's phone number."
        },
        "role": {
          "type": "string",
          "description": "User's role within the application (Owner, Planner, Guest, Security, Cohost)."
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "phoneNumber",
        "role"
      ]
    },
    "NotificationLog": {
      "title": "NotificationLog",
      "type": "object",
      "description": "A record of an outgoing notification attempt across multiple channels.",
      "properties": {
        "id": { "type": "string" },
        "recipient": {
            "type": "object",
            "properties": {
                "email": { "type": "string" },
                "phone": { "type": "string" }
            }
        },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "templateId": { "type": "string" },
        "results": {
            "type": "object",
            "description": "Results of the delivery attempt for each channel."
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "message", "timestamp"]
    },
    "Show": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Show",
      "type": "object",
      "description": "Represents a public, ticketed show created within the EvenTide application by a Ticketier.",
      "properties": {
        "showId": {
          "type": "string",
          "description": "Unique identifier for the Show entity."
        },
        "ownerId": {
          "type": "string",
          "description": "Reference to UserProfile representing the show owner (Ticketier)."
        },
        "eventCode": { "type": "string", "description": "Unique alphanumeric code for the show." },
        "eventType": {
          "type": "string",
          "description": "Type of show (Concert, Festival, etc.)."
        },
        "name": {
          "type": "string",
          "description": "Name of the show."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the show."
        },
        "eventDate": {
          "type": "string",
          "description": "Date and time of the show.",
          "format": "date-time"
        },
        "location": {
          "type": "string",
          "description": "Location of the show."
        },
        "imageUrls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "description": "An array of URLs for show images."
        },
        "isPublic": {
          "type": "boolean",
          "description": "Indicates whether the show is public or private. Should be true for shows."
        },
        "isTicketed": {
          "type": "boolean",
          "description": "Indicates if the show requires tickets for entry. Should be true for shows."
        }
      },
      "required": [
        "showId",
        "ownerId",
        "eventCode",
        "eventType",
        "name",
        "description",
        "eventDate",
        "location",
        "imageUrls",
        "isPublic",
        "isTicketed"
      ]
    },
    "Event": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Event",
      "type": "object",
      "description": "Represents a private event created within the EvenTide application by a Host.",
      "properties": {
        "eventId": { "type": "string" },
        "ownerId": { "type": "string" },
        "eventCode": { "type": "string" },
        "eventType": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "eventDate": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string", "format": "uri" }},
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "securityCode": { "type": "string", "description": "A temporary code for on-site security to activate scanners." },
        "plannerIds": { "type": "array", "items": { "type": "string" }, "description": "List of user IDs for assigned planners." },
        "cohostIds": { "type": "object", "description": "Map of user IDs for assigned co-hosts." },
        "acceptedVendorIds": { "type": "array", "items": { "type": "string" }, "description": "List of user IDs for vendors with accepted contracts." },
        "curatedGalleries": {
          "type": "array",
          "description": "AI-curated photo galleries from the event.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "imageUrls": { "type": "array", "items": { "type": "string", "format": "uri" }}
            },
            "required": ["id", "title", "imageUrls"]
          }
        }
      },
      "required": ["eventId", "ownerId", "eventCode", "eventType", "name", "description", "eventDate", "location", "imageUrls", "primaryColor", "secondaryColor", "plannerIds", "cohostIds"]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/notification_logs/{logId}",
        "definition": {
            "entityName": "NotificationLog",
            "schema": { "$ref": "#/backend/entities/NotificationLog" },
            "description": "Platform-wide audit log for all outgoing notifications."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores user profile information. Path-based ownership ensures only the user can access their own profile."
        }
      }
    ]
  }
}
