/**
 * Core Philosophy: This ruleset enforces a security model centered around event collaboration and user data privacy.
 * The primary goal is to ensure that users have exclusive control over their personal data, while event data
 * can be securely shared among legitimate participants (owners, planners, co-hosts, etc.).
 *
 * Data Structure: The database is organized into several top-level collections:
 * - /users/{userId}: Stores private user profiles, accessible only by the user themselves.
 * - /events/{eventId}: The central hub for all event-related data. Each event document acts as a parent for numerous
 *   subcollections that manage different aspects of the event (guests, chat, media).
 * - /price_plans/{pricePlanId}: A public, read-only collection containing pricing information.
 *
 * Key Security Decisions:
 * - User Isolation: A user's profile in `/users/{userId}` is strictly private. User listing is disabled to prevent data scraping.
 * - Event Membership: Access to an event and its subcollections is determined by a user's role (Owner, Planner, Co-host).
 *   These roles are established by the existence of corresponding documents in subcollections like `/planners` and `/cohosts`.
 * - Denormalization for Authorization: To secure subcollections, rules must look up roles from the parent event context.
 *   This is achieved using `get()` to read the event's `ownerId` and `exists()` to check for planner/co-host membership documents.
 *   While the ideal state described in the design reasoning is a denormalized `members` map on the event document, these
 *   lookups are a necessary intermediate step given the current collection-based membership structure.
 * - Public vs. Private Events: The `isPublic` flag on an event document dictates its visibility. Public events are readable
 *   by anyone, while private events are restricted to event staff.
 * - Guest Access Limitation: Due to the current data model where guest identity (`userProfileId`) is stored inside a guest
 *   document (with a random ID), it is not possible for security rules to efficiently verify if a requesting user is a guest
 *   for shared resources like `/chat_messages`. Therefore, access to collaborative subcollections is currently restricted to
 *   event staff (Owners, Planners, Co-hosts) who can be securely and efficiently verified.
 *
 * Prototyping Mode: These rules prioritize strong authorization (who can access what) but remain flexible on data shapes.
 * Validation is limited to fields critical for establishing ownership and relational integrity, allowing for rapid
 * application development and iteration.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions for Reusability and Readability

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the document being written to already exists.
     * CRITICAL for preventing updates or deletes on non-existent documents.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Retrieves the parent event document data. Used by subcollection rules.
     * This incurs a read operation but is necessary for secure context.
     */
    function getEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    /**
     * Checks if the requesting user is the owner of the specified event.
     */
    function isEventOwner(eventId) {
      let eventData = getEvent(eventId).data;
      return isSignedIn() && eventData.ownerId == request.auth.uid;
    }

    /**
     * Checks if the requesting user is listed as a planner for the event.
     * Assumes the planner document ID is the user's UID.
     */
    function isEventPlanner(eventId) {
      return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/planners/$(request.auth.uid));
    }

    /**
     * Checks if the requesting user is listed as a co-host for the event.
     * Assumes the co-host document ID is the user's UID.
     */
    function isEventCohost(eventId) {
      return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/cohosts/$(request.auth.uid));
    }

    /**
     * Checks if the user is part of the event's management staff (Owner, Planner, or Co-host).
     */
    function isEventStaff(eventId) {
      return isEventOwner(eventId) || isEventPlanner(eventId) || isEventCohost(eventId);
    }

    /**
     * Determines if a user can read data within an event's context (subcollections).
     * Grants access to event staff. Extensible to other roles if the data model allows.
     */
    function canReadEventData(eventId) {
      // NOTE: Guest access is not included due to data modeling limitations.
      // See Key Security Decisions in the main documentation block.
      return isEventStaff(eventId);
    }


    /**
     * @description Secure access to a user's private profile.
     * @path /users/{userId}
     * @allow (create) A signed-in user (UID 'user123') creates their own profile at '/users/user123'.
     * @deny (read) A signed-in user (UID 'user456') tries to read the profile at '/users/user123'.
     * @principle Restricts access to a user's own data tree using path-based ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Disallow listing/querying users for privacy.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    /**
     * @description Manages access to event documents. Public events are readable by all.
     * Writes are restricted to the event owner.
     * @path /events/{eventId}
     * @allow (read) Any user (even unauthenticated) reads an event document where `isPublic` is true.
     * @allow (write) The user whose UID matches the `ownerId` creates a new event.
     * @deny (read) An unauthenticated user tries to read a private event (`isPublic` is false).
     * @deny (write) A user who is not the owner tries to delete the event.
     * @principle Enforces a "Public Read with Owner-Only Writes" pattern.
     */
    match /events/{eventId} {
      allow get: if resource.data.isPublic == true || isEventStaff(eventId);
      allow list: if true; // Allows clients to query for public events.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isEventOwner(eventId) && isExistingDoc() && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isEventOwner(eventId) && isExistingDoc();
    }

    /**
     * @description Manages the guest list for an event.
     * @path /events/{eventId}/guests/{guestId}
     * @allow (read) An event staff member reads the details of a guest. A guest reads their own details.
     * @allow (write) An event staff member adds, updates, or removes a guest from the list.
     * @deny (list) A random user tries to list all guests for an event.
     * @principle Access is delegated from the parent event, controlled by event staff roles.
     */
    match /events/{eventId}/guests/{guestId} {
      allow get: if canReadEventData(eventId) || isOwner(guestId);
      allow list: if canReadEventData(eventId);
      allow create: if isEventStaff(eventId) && request.resource.data.eventId == eventId;
      allow update: if (isEventStaff(eventId) || isOwner(guestId)) && isExistingDoc();
      allow delete: if isEventStaff(eventId) && isExistingDoc();
    }

    /**
     * @description Manages the planner list for an event. Only the event owner can modify this list.
     * @path /events/{eventId}/planners/{plannerId}
     * @allow (create) The event owner adds a new planner to the event.
     * @deny (delete) A planner tries to remove another planner from the event.
     * @principle Membership management is restricted to the primary resource owner.
     */
    match /events/{eventId}/planners/{plannerId} {
      allow get, list: if canReadEventData(eventId);
      allow create: if isEventOwner(eventId) && request.resource.data.eventId == eventId && request.resource.data.plannerId == plannerId;
      allow update: if isEventOwner(eventId) && isExistingDoc();
      allow delete: if isEventOwner(eventId) && isExistingDoc();
    }

    /**
     * @description Manages the co-host list for an event. Only the event owner can modify this list.
     * @path /events/{eventId}/cohosts/{cohostId}
     * @allow (create) The event owner adds a new co-host to the event.
     * @deny (delete) A co-host tries to remove another co-host from the event.
     * @principle Membership management is restricted to the primary resource owner.
     */
    match /events/{eventId}/cohosts/{cohostId} {
      allow get, list: if canReadEventData(eventId);
      allow create: if isEventOwner(eventId) && request.resource.data.eventId == eventId && request.resource.data.cohostId == cohostId;
      allow update: if isEventOwner(eventId) && isExistingDoc();
      allow delete: if isEventOwner(eventId) && isExistingDoc();
    }

    /**
     * @description Secures the chat messages for an event.
     * @path /events/{eventId}/chat_messages/{messageId}
     * @allow (create) An event staff member sends a message.
     * @deny (read) A user not associated with the event tries to read chat messages.
     * @principle Access is restricted to verified event staff. Messages are immutable.
     */
    match /events/{eventId}/chat_messages/{messageId} {
      allow get, list: if canReadEventData(eventId);
      allow create: if isEventStaff(eventId) && request.resource.data.senderId == request.auth.uid && request.resource.data.eventId == eventId;
      allow update: if false; // Chat messages should be immutable.
      allow delete: if (isEventStaff(eventId) || isOwner(resource.data.senderId)) && isExistingDoc();
    }

    /**
     * @description Secures the media gallery for an event.
     * @path /events/{eventId}/media/{mediaId}
     * @allow (create) An event staff member uploads a photo.
     * @deny (delete) A random user tries to delete a photo from the event's gallery.
     * @principle Access is restricted to verified event staff. Media uploads are immutable.
     */
    match /events/{eventId}/media/{mediaId} {
      allow get, list: if canReadEventData(eventId);
      allow create: if isEventStaff(eventId) && request.resource.data.uploaderId == request.auth.uid && request.resource.data.eventId == eventId;
      allow update: if false; // Media metadata is immutable.
      allow delete: if (isEventStaff(eventId) || isOwner(resource.data.uploaderId)) && isExistingDoc();
    }

    /**
     * @description Publicly readable pricing plan information.
     * @path /price_plans/{pricePlanId}
     * @allow (read) Any client application can read the available price plans.
     * @deny (write) No client can create, update, or delete price plans.
     * @principle Defines a public, read-only data collection.
     */
    match /price_plans/{pricePlanId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages the assigned pricing plan for an event.
     * @path /events/{eventId}/event_pricing/{pricingId}
     * @allow (create) The event owner assigns a pricing plan to their event.
     * @deny (update) Anyone other than the event owner tries to change the event's plan.
     * @principle Access is delegated from the parent event and restricted to the owner.
     */
    match /events/{eventId}/event_pricing/{pricingId} {
      allow get, list: if canReadEventData(eventId);
      allow create: if isEventOwner(eventId) && request.resource.data.eventId == eventId;
      allow update: if isEventOwner(eventId) && isExistingDoc();
      allow delete: if isEventOwner(eventId) && isExistingDoc();
    }

    /**
     * @description Manages sensitive security codes for an event.
     * @path /events/{eventId}/security_codes/{securityCodeId}
     * @allow (read) An event staff member views a security code.
     * @deny (list) A security person tries to list all other security codes.
     * @principle Access to sensitive data is highly restricted to management roles.
     */
    match /events/{eventId}/security_codes/{securityCodeId} {
      allow get: if isEventStaff(eventId) || isOwner(securityCodeId);
      allow list: if isEventStaff(eventId);
      allow create: if isEventStaff(eventId) && request.resource.data.eventId == eventId;
      allow update: if isEventStaff(eventId) && isExistingDoc();
      allow delete: if isEventStaff(eventId) && isExistingDoc();
    }

    /**
     * @description Manages announcements for an event.
     * @path /events/{eventId}/announcements/{announcementId}
     * @allow (create) An event staff member posts a new announcement.
     * @deny (update) A guest or random user tries to edit an announcement.
     * @principle Content creation and moderation is restricted to verified event staff.
     */
    match /events/{eventId}/announcements/{announcementId} {
      allow get, list: if canReadEventData(eventId);
      allow create: if isEventStaff(eventId) && request.resource.data.authorId == request.auth.uid && request.resource.data.eventId == eventId;
      allow update: if isEventStaff(eventId) && isExistingDoc();
      allow delete: if isEventStaff(eventId) && isExistingDoc();
    }
  }
}