

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

      // --- Start of Corrected Event-Scoped Helpers ---

      function isSignedIn() {
        return request.auth != null;
      }

      function isEventOwner() {
        return isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

      function isEventPlanner() {
        return isSignedIn() && resource.data.plannerIds != null
              && request.auth.uid in resource.data.plannerIds;
      }

      function isEventCohost() {
        return isSignedIn() && resource.data.cohostIds != null
              && resource.data.cohostIds[request.auth.uid] == true;
      }

      function isEventStaff() {
        return isEventOwner() || isEventPlanner() || isEventCohost();
      }

      function isEventGuest(eventId) {
        // Check if a guest document exists for the current user for this event.
        // This is a placeholder for a more specific check, like against a guest's userProfileId
        return isSignedIn() && exists(/databases/$(database)/documents/events/$(eventId)/guests/$(request.auth.uid));
      }

      // --- End of Corrected Event-Scoped Helpers ---


      // --- Start of General Helpers ---
      
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingDoc() {
        return resource != null;
      }

      function isEventOwnerOnCreate() {
        return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      }

      function getUserRole(userId) {
          return get(/databases/$(database)/documents/users/$(userId)).data.role;
      }

      function isAdmin() {
          let role = getUserRole(request.auth.uid);
          return isSignedIn() && (role == 'Super Admin' || role == 'Content Admin' || role == 'Editorial Admin');
      }

      function getShow(showId) {
        return get(/databases/$(database)/documents/shows/$(showId));
      }

      function isShowOwner(showId) {
          // Use `resource.data` for existing documents
          return isSignedIn() && resource.data.ownerId == request.auth.uid;
      }
      
      function isEventGuestByDoc(guestDoc) {
          return isSignedIn() && guestDoc.userProfileId == request.auth.uid;
      }
      
      // --- End of General Helpers ---

      match /users/{userId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if request.auth.uid == userId;
        allow update: if isOwner(userId) && isExistingDoc() && request.resource.data.id == resource.data.id;
        allow delete: if isOwner(userId) && isExistingDoc();

        match /notifications/{notificationId} {
          allow read, delete: if isOwner(userId);
          allow create: if isSignedIn();
          allow update: if isOwner(userId) && request.resource.data.read == true;
        }
      }

      match /users/{document=**} {
          allow list: if isSignedIn();
      }

      match /planners/{plannerId} {
          allow read, write: if isOwner(plannerId);
      }

      match /plannerProfiles/{plannerId} {
          allow get, list: if true;
          allow create: if request.auth.uid == plannerId;
          allow update, delete: if isOwner(plannerId);
      }

      match /ticketiers/{ticketierId} {
          allow get: if true;
          allow list: if true;
          allow create: if request.auth.uid == ticketierId;
          allow update: if isOwner(ticketierId);
          allow delete: if false;
      }

      match /vendors/{vendorId} {
          allow get, list: if true;
          allow create: if request.auth.uid == vendorId;
          allow update, delete: if isOwner(vendorId);
      }

      match /shows/{showId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isShowOwner(showId);
        allow delete: if isShowOwner(showId);
      }

      match /shows/{showId}/ticketTiers/{tierId} {
          allow get, list: if true;
          allow create, update, delete: if isShowOwner(showId);
      }

      match /shows/{showId}/tickets/{ticketId} {
          allow get, list: if isShowOwner(showId) || isOwner(resource.data.buyerId);
          allow create: if isSignedIn();
          allow update, delete: if isShowOwner(showId);
      }
      
      match /events/{eventId} {
        allow create: if isEventOwnerOnCreate();
        allow get: if isEventStaff() || isEventGuest(eventId);
        allow update, delete: if isEventStaff();
        allow list: if true;

        match /tasks/{taskId} {
          allow read, create, update, delete: if isEventStaff();
        }

        match /guests/{guestId} {
            allow get: if isEventStaff() || isEventGuestByDoc(resource.data);
            allow list: if isEventStaff();
            allow create: if isEventStaff();
            allow update: if isEventStaff() || 
                           (isEventGuestByDoc(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvpStatus'])) ||
                           (isSignedIn() && resource.data.userProfileId == null && request.resource.data.userProfileId == request.auth.uid);
            allow delete: if isEventStaff();
        }

        match /expenses/{expenseId} {
            allow read, create, update, delete: if isEventStaff();
        }

        match /tables/{tableId} {
          allow read, create, update, delete: if isEventStaff();
          match /seats/{seatId} {
            allow read, create, update, delete: if isEventStaff();
          }
        }
        
        match /gifts/{giftId} {
          allow read: if true; 
          allow create, delete: if isEventStaff();
          allow update: if isEventStaff() || isEventGuest(eventId); 
        }
      
        match /songRequests/{requestId} {
          allow create: if isEventGuest(eventId);
          allow read, update, delete: if isEventStaff();
        }

        match /fashionContracts/{contractId} {
            allow create: if isEventOwner();
            allow read, update: if isEventStaff() || isOwner(resource.data.designerId);
            allow delete: if isEventOwner();

            match /messages/{messageId} {
              allow read, create: if isEventStaff() || isOwner(get(/databases/$(database)/documents/events/$(eventId)/fashionContracts/$(contractId)).data.designerId);
              allow update, delete: if isOwner(resource.data.senderId);
            }
        }
      
        match /event_pricing/{pricingId} {
            allow read, create, update, delete: if isEventStaff();
        }

        match /program/{docId} {
          allow read, write: if isEventStaff();
        }

        match /menu/{docId} {
          allow read, write: if isEventStaff();
        }
        
        match /shotLists/{shotListId} {
          allow read, write: if isEventStaff();
        }
        
        match /moodboard/{moodboardId} {
            allow read, create, update, delete: if isEventStaff();
        }

        match /chat_messages/{messageId} {
            allow read, list: if isEventStaff() || isEventGuest(eventId);
            allow create: if (isEventStaff() || isEventGuest(eventId)) && request.resource.data.senderId == request.auth.uid;
            allow update: if false; 
            allow delete: if isEventStaff() || isOwner(resource.data.senderId);
        }

        match /media/{mediaId} {
            allow read, list: if isEventStaff() || isEventGuest(eventId);
            allow create: if (isEventStaff() || isEventGuest(eventId)) && request.resource.data.uploaderId == request.auth.uid;
            allow update: if false; 
            allow delete: if isEventStaff() || isOwner(resource.data.uploaderId);
        }

        match /security_codes/{securityCodeId} {
          allow read, list, create, update, delete: if isEventStaff();
        }

        match /announcements/{announcementId} {
          allow read: if isEventStaff() || isEventGuest(eventId);
          allow create, update, delete: if isEventStaff();
        }
      }

      match /price_plans/{pricePlanId} {
        allow read, list: if true;
        allow write: if false;
      }

      match /cars/{carId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
          allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      }
      
      match /carBookings/{bookingId} {
          allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.carOwnerId == request.auth.uid);
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource.data.carOwnerId == request.auth.uid;
      }

      match /venues/{venueId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
          allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

       match /venueBookings/{bookingId} {
          allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.venueOwnerId == request.auth.uid);
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource.data.venueOwnerId == request.auth.uid;
      }

      match /hotels/{hotelId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
          allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

       match /bookings/{bookingId} {
          allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.hotelOwnerId == request.auth.uid);
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource.data.hotelOwnerId == request.auth.uid;
      }

      match /magazineIssues/{issueId} {
          allow get: if resource.data.status == 'published' || isAdmin();
          allow list: if true;
          allow create, update, delete: if isAdmin();
      }

      match /adRequests/{requestId} {
          allow create: if isSignedIn();
          allow read, update, delete: if isAdmin();
      }

      match /testimonials/{testimonialId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if false; 
      }
       match /supportTickets/{ticketId} {
          allow create: if true;
          allow read, update, delete: if false;
      }
    }
  }

    