rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

      // --- Start of General Helper Functions ---
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function getUserRole(userId) {
          return get(/databases/$(database)/documents/users/$(userId)).data.role;
      }

      function isAdmin() {
          let role = getUserRole(request.auth.uid);
          return isSignedIn() && (role == 'Super Admin' || role == 'Content Admin' || role == 'Editorial Admin');
      }
      // --- End of General Helper Functions ---


      // --- Start of Event-Scoped Helper Functions ---
      function getEvent(eventId) {
        return get(/databases/$(database)/documents/events/$(eventId));
      }
      
      function isEventOwner(eventId) {
        let event = getEvent(eventId);
        return isSignedIn() && event.data.ownerId == request.auth.uid;
      }

      function isEventPlanner(eventId) {
        let event = getEvent(eventId);
        return isSignedIn() && event.data.plannerIds != null && request.auth.uid in event.data.plannerIds;
      }

      function isEventStaff(eventId) {
        let event = getEvent(eventId);
        return isSignedIn() && (
          event.data.ownerId == request.auth.uid ||
          (event.data.plannerIds != null && request.auth.uid in event.data.plannerIds) ||
          (event.data.cohostIds != null && event.data.cohostIds[request.auth.uid] == true)
        );
      }

       function isEventGuest(eventId, guestId) {
          return isSignedIn() && request.auth.uid == guestId;
       }
      // --- End of Event-Scoped Helper Functions ---

      // --- Start of Security Rule Definitions ---
      match /users/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || request.auth == null; 
        allow update, delete: if isOwner(userId) || isAdmin();
        allow list: if isSignedIn();

        match /notifications/{notificationId} {
          allow read, delete: if isOwner(userId) || isAdmin();
          allow create: if isSignedIn();
          allow update: if isOwner(userId) && request.resource.data.read == true;
        }

        match /contacts/{contactId} {
            allow read, write: if isOwner(userId);
        }
      }

      match /planners/{plannerId} {
          allow read: if isOwner(plannerId) || isAdmin();
          allow write: if isOwner(plannerId) || isSignedIn() || isAdmin();

          match /assignments/{assignmentId} {
              allow read, list: if isOwner(plannerId) || isAdmin();
              allow create: if isSignedIn();
              allow update: if isOwner(plannerId) || isAdmin(); 
          }
      }

      match /shows/{showId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

        match /ticketTiers/{tierId} {
            allow read, list: if true;
            allow create, update, delete: if isSignedIn();
        }

        match /tickets/{ticketId} {
            allow read: if (isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.ownerId == request.auth.uid)) || isAdmin();
            allow list: if isSignedIn();
            allow create: if isSignedIn();
        }
      }
      
      match /events/{eventId} {
        allow create: if isSignedIn();
        allow get: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid) || isAdmin();
        allow update: if isEventStaff(eventId) || isAdmin();
        allow delete: if isEventOwner(eventId) || isAdmin();
        allow list: if isSignedIn();
        
        match /planners/{plannerId} {
            allow create: if isSignedIn(); 
            allow read, list: if isEventStaff(eventId) || isAdmin() || isOwner(plannerId);
            allow update, delete: if isEventStaff(eventId) || isAdmin() || isOwner(plannerId);
        }

        match /guests/{guestId} {
            allow get: if isEventStaff(eventId) || (isSignedIn() && request.auth.uid == guestId) || isAdmin();
            allow read: if isEventStaff(eventId) || (isSignedIn() && request.auth.uid == guestId) || isAdmin();
            allow list: if isEventStaff(eventId) || isAdmin();
            allow create: if isEventStaff(eventId) || isAdmin();
            allow delete: if isEventStaff(eventId) || isAdmin();
            allow update: if isEventStaff(eventId) || (isEventGuest(eventId, guestId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvpStatus', 'name']));
        }

        match /guestCodes/{guestCode} {
            allow read: if true; 
            allow create, update, delete: if isEventStaff(eventId) || isAdmin();
        }

        match /tasks/{taskId} {
          allow read, write: if isEventStaff(eventId) || isAdmin();
        }

        match /expenses/{expenseId} {
            allow read, write: if isEventStaff(eventId) || isAdmin();
        }

        match /tables/{tableId} {
          allow read, write: if isEventStaff(eventId) || isAdmin();
        }
        
        match /seats/{seatId} {
            allow read, write: if isEventStaff(eventId) || isAdmin();
        }
        
        match /gifts/{giftId} {
            allow read: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid) || isAdmin();
            allow create, delete: if isEventStaff(eventId) || isAdmin();
            allow update: if isEventStaff(eventId) ||
                           (isEventGuest(eventId, request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claimedCount', 'claimedBy']));
        }
      
        match /songRequests/{requestId} {
          allow create: if isEventGuest(eventId, request.resource.data.requesterId);
          allow read: if isEventStaff(eventId) || isAdmin();
          allow update, delete: if isEventStaff(eventId) || isAdmin();
        }

        match /program/{docId} {
          allow read: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid) || isAdmin();
          allow write: if isEventStaff(eventId) || isAdmin();
        }

        match /menu/{docId} {
          allow read: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid) || isAdmin();
          allow write: if isEventStaff(eventId) || isAdmin();
        }
        
        match /shotLists/{shotListId} {
          allow read, write: if isEventStaff(eventId) || isAdmin();
        }
        
        match /moodboard/{moodboardId} {
            allow read, write: if isEventStaff(eventId) || isAdmin();
        }

        match /chat_messages/{messageId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid) || isAdmin();
            allow create: if (isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid)) && isOwner(request.resource.data.senderId);
            allow update, delete: if false; 
        }

        match /media/{mediaId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid) || isAdmin();
            allow create: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid);
            allow delete: if isEventStaff(eventId) || isOwner(resource.data.uploaderId);
            allow update: if false;
        }

        match /announcements/{announcementId} {
          allow read: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid) || isAdmin();
          allow create: if isEventStaff(eventId) || isAdmin();
          allow update, delete: if isEventStaff(eventId) || isAdmin();
        }

        match /polls/{pollId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid);
            allow create, delete: if isEventStaff(eventId) || isAdmin();
            allow update: if (isEventGuest(eventId, request.auth.uid) && !(request.auth.uid in resource.data.voters)) || isEventStaff(eventId);
        }
        
        match /autographs/{autographId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId, request.auth.uid);
            allow create: if isEventGuest(eventId, request.auth.uid);
            allow delete: if isEventStaff(eventId);
        }
      }

      match /price_plans/{pricePlanId} {
        allow read, list: if true;
        allow write: if isAdmin();
      }

      match /cars/{carId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
      }
      
      match /carBookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.carOwnerId) || isAdmin();
      }

      match /venues/{venueId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
      }

       match /venueBookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.venueOwnerId) || isAdmin();
      }

      match /hotels/{hotelId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
      }

       match /bookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.hotelOwnerId) || isAdmin();
      }

      match /magazineIssues/{issueId} {
          allow get: if resource.data.status == 'published' || isAdmin();
          allow list: if true;
          allow create, update, delete: if isAdmin();
      }

      match /adRequests/{requestId} {
          allow create: if isSignedIn();
          allow read, update, delete: if isAdmin();
      }

      match /testimonials/{testimonialId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isAdmin();
      }
       match /supportTickets/{ticketId} {
          allow create: if true;
          allow read, update, delete: if isAdmin();
      }
    }
  }
