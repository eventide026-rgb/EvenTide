

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

      // --- Start of General Helper Functions ---
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingDoc() {
        return resource != null;
      }

      function isEventOwnerOnCreate() {
        // Use this only for event creation where `resource` is null.
        return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      }
      
      function getUserRole(userId) {
          return get(/databases/$(database)/documents/users/$(userId)).data.role;
      }

      function isAdmin() {
          let role = getUserRole(request.auth.uid);
          return isSignedIn() && (role == 'Super Admin' || role == 'Content Admin' || role == 'Editorial Admin');
      }
      // --- End of General Helper Functions ---


      // --- Start of Event-Scoped Helper Functions ---
      function getEvent(eventId) {
        return get(/databases/$(database)/documents/events/$(eventId));
      }
      
      function isEventOwner(eventId) {
        let event = getEvent(eventId);
        return isSignedIn() && event.data.ownerId == request.auth.uid;
      }

      function isEventPlanner(eventId) {
        let event = getEvent(eventId);
        // Ensure plannerIds is not null and is a list before checking
        return isSignedIn() && event.data.plannerIds != null && request.auth.uid in event.data.plannerIds;
      }

      function isEventCohost(eventId) {
        let event = getEvent(eventId);
        // Ensure cohostIds is not null and is a map before checking
        return isSignedIn() && event.data.cohostIds != null && event.data.cohostIds[request.auth.uid] == true;
      }

      function isEventStaff(eventId) {
        let event = getEvent(eventId);
        return isSignedIn() && (
          event.data.ownerId == request.auth.uid ||
          (event.data.plannerIds != null && request.auth.uid in event.data.plannerIds) ||
          (event.data.cohostIds != null && event.data.cohostIds[request.auth.uid] == true)
        );
      }

       function isEventGuest(eventId) {
          let guestDocPath = /databases/$(database)/documents/events/$(eventId)/guests/$(request.auth.uid);
          return isSignedIn() && exists(guestDocPath);
       }
      // --- End of Event-Scoped Helper Functions ---
      

      // --- Start of Security Rule Definitions ---
      match /users/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || request.auth == null; // Allow creation for new users
        allow update, delete: if isOwner(userId) || isAdmin();
        allow list: if isSignedIn();

        match /notifications/{notificationId} {
          allow read, delete: if isOwner(userId) || isAdmin();
          allow create: if isSignedIn();
          allow update: if isOwner(userId) && request.resource.data.read == true;
        }
      }

      match /planners/{plannerId} {
          allow read, write: if isOwner(plannerId) || isAdmin();
      }

      match /plannerProfiles/{plannerId} {
          allow get, list: if true;
          allow create: if request.auth.uid == plannerId;
          allow update, delete: if isOwner(plannerId) || isAdmin();
      }

      match /ticketiers/{ticketierId} {
          allow get, list: if true;
          allow create: if request.auth.uid == ticketierId;
          allow update, delete: if isOwner(ticketierId) || isAdmin();
      }

      match /vendors/{vendorId} {
          allow get, list: if true;
          allow create: if request.auth.uid == vendorId;
          allow update, delete: if isOwner(vendorId) || isAdmin();
      }

      match /shows/{showId} {
        allow read, list: if true;
        allow create: if isEventOwnerOnCreate();
        allow update, delete: if isEventOwner(showId) || isAdmin();
      }

      match /shows/{showId}/{document=**} {
          allow read, list, write: if isEventOwner(showId) || isAdmin();
      }
      
      match /events/{eventId} {
        allow create: if isEventOwnerOnCreate();
        allow get: if isEventStaff(eventId) || isEventGuest(eventId) || isAdmin();
        allow update: if isEventStaff(eventId) || isAdmin();
        allow delete: if isEventOwner(eventId) || isAdmin();
        allow list: if isSignedIn();
        
        match /planners/{plannerId} {
            allow create: if isEventOwner(eventId);
            allow read, list: if isEventStaff(eventId) || isAdmin();
            allow update, delete: if isEventStaff(eventId) || isAdmin();
        }

        match /guests/{guestId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId) || isAdmin();
            allow create: if isEventStaff(eventId) || isAdmin();
            allow delete: if isEventStaff(eventId) || isAdmin();
            allow update: if isEventStaff(eventId) || 
                           (isEventGuest(eventId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvpStatus'])) ||
                           // Allow a newly signed-in anonymous user to claim their guest document
                           (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['id']) && request.resource.data.id == request.auth.uid);
        }

        match /guestCodes/{guestCode} {
            allow read: if true; // Publicly readable for login
            allow create, update, delete: if isEventStaff(eventId) || isAdmin();
        }

        match /tasks/{taskId} {
          allow read, write: if isEventStaff(eventId) || isAdmin();
        }

        match /expenses/{expenseId} {
            allow read, write: if isEventStaff(eventId) || isAdmin();
        }

        match /tables/{tableId} {
          allow read, write: if isEventStaff(eventId) || isAdmin();
        }
        
        match /seats/{seatId} {
            allow read, write: if isEventStaff(eventId) || isAdmin();
        }
        
        match /gifts/{giftId} {
            allow read: if isEventStaff(eventId) || isEventGuest(eventId) || isAdmin();
            allow create, delete: if isEventStaff(eventId) || isAdmin();
            allow update: if isEventStaff(eventId) ||
                           (isEventGuest(eventId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claimedCount', 'claimedBy']));
        }
      
        match /songRequests/{requestId} {
          allow create: if isEventGuest(eventId);
          allow read: if isEventStaff(eventId) || isAdmin();
          allow update, delete: if isEventStaff(eventId) || isAdmin();
        }

        match /fashionContracts/{contractId} {
            allow create: if isEventOwner(eventId) || isEventPlanner(eventId);
            allow read, update: if isEventStaff(eventId) || isOwner(resource.data.designerId);
            allow delete: if isEventOwner(eventId);
        }
      
        match /program/{docId} {
          allow read: if isEventStaff(eventId) || isEventGuest(eventId) || isAdmin();
          allow write: if isEventStaff(eventId) || isAdmin();
        }

        match /menu/{docId} {
          allow read: if isEventStaff(eventId) || isEventGuest(eventId) || isAdmin();
          allow write: if isEventStaff(eventId) || isAdmin();
        }
        
        match /shotLists/{shotListId} {
          allow read, write: if isEventStaff(eventId) || isAdmin();
        }
        
        match /moodboard/{moodboardId} {
            allow read, write: if isEventStaff(eventId) || isAdmin();
        }

        match /chat_messages/{messageId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId) || isAdmin();
            allow create, delete: if isEventStaff(eventId) || (isEventGuest(eventId) && isOwner(request.resource.data.senderId));
            allow update: if false; // Messages are immutable
        }

        match /media/{mediaId} {
            allow read, list: if isEventStaff(eventId) || isEventGuest(eventId) || isAdmin();
            allow create: if isEventStaff(eventId) || isEventGuest(eventId);
            allow delete: if isEventStaff(eventId) || isOwner(resource.data.uploaderId);
            allow update: if false;
        }

        match /security_codes/{securityCodeId} {
          allow read, list, create, update, delete: if isEventStaff(eventId) || isAdmin();
        }

        match /announcements/{announcementId} {
          allow read: if isEventStaff(eventId) || isEventGuest(eventId) || isAdmin();
          allow create, update, delete: if isEventStaff(eventId) || isAdmin();
        }
      }

      match /price_plans/{pricePlanId} {
        allow read, list: if true;
        allow write: if isAdmin();
      }

      match /cars/{carId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
      }
      
      match /carBookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.carOwnerId) || isAdmin();
      }

      match /venues/{venueId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
      }

       match /venueBookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.venueOwnerId) || isAdmin();
      }

      match /hotels/{hotelId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
      }

       match /bookings/{bookingId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOwner(resource.data.hotelOwnerId) || isAdmin();
      }

      match /magazineIssues/{issueId} {
          allow get: if resource.data.status == 'published' || isAdmin();
          allow list: if true;
          allow create, update, delete: if isAdmin();
      }

      match /adRequests/{requestId} {
          allow create: if isSignedIn();
          allow read, update, delete: if isAdmin();
      }

      match /testimonials/{testimonialId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isAdmin();
      }
       match /supportTickets/{ticketId} {
          allow create: if true;
          allow read, update, delete: if isAdmin();
      }
    }
  }
